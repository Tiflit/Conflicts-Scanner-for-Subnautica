<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ConflictScanner.Converters"
             x:Class="ConflictScanner.App">

  <Application.Styles>
    <FluentTheme />
  </Application.Styles>

  <Application.Resources>
    <conv:BooleanNegationConverter x:Key="BooleanNegationConverter" />
    <!-- Overlay brush for scan in progress -->
    <SolidColorBrush x:Key="ScanOverlayBrush" Color="#CC1A1A1A" />
  </Application.Resources>

</Application>
